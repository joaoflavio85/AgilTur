// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           Int       @id @default(autoincrement())
  empresaId    Int?
  nome         String    @db.NVarChar(150)
  email        String    @db.NVarChar(200)
  senha        String    @db.NVarChar(255)
  telefone     String?   @db.NVarChar(20)
  perfil       String    @default("AGENTE") @db.NVarChar(10)
  ativo        Boolean   @default(true)
  dataCriacao  DateTime  @default(now())

  vendas       Venda[]
  propostas    Proposta[]

  @@unique([empresaId, email])
  @@map("usuarios")
}

model Cliente {
  id            Int       @id @default(autoincrement())
  empresaId     Int?
  nome          String    @db.NVarChar(150)
  cpf           String    @db.NVarChar(14)
  rg            String?   @db.NVarChar(20)
  dataNascimento DateTime?
  telefone      String?   @db.NVarChar(20)
  email         String?   @db.NVarChar(200)
  endereco      String?   @db.NVarChar(500)
  observacoes   String?   @db.NVarChar(1000)
  dataCadastro  DateTime  @default(now())

  vendas        Venda[]
  propostas     Proposta[]

  @@unique([empresaId, cpf])
  @@map("clientes")
}

model Operadora {
  id           Int       @id @default(autoincrement())
  empresaId    Int?
  nome         String    @db.NVarChar(150)
  cnpj         String?   @db.NVarChar(18)
  telefone     String?   @db.NVarChar(20)
  email        String?   @db.NVarChar(200)
  ativo        Boolean   @default(true)
  dataCadastro DateTime  @default(now())

  vendas       Venda[]
  propostas    Proposta[]
  modelosPosVenda ModeloPosVenda[]

  @@map("operadoras")
}

model ModeloPosVenda {
  id             Int        @id @default(autoincrement())
  empresaId      Int?
  tipoServico    String     @db.NVarChar(20)
  operadoraId    Int?
  tipoAcao       String     @db.NVarChar(20)
  descricaoPadrao String    @db.NVarChar(1000)
  ordem          Int        @default(1)
  ativo          Boolean    @default(true)
  dataCriacao    DateTime   @default(now())

  operadora      Operadora? @relation(fields: [operadoraId], references: [id])

  @@index([tipoServico, operadoraId, ativo, ordem])
  @@map("modelos_pos_venda")
}

model Proposta {
  id               Int        @id @default(autoincrement())
  empresaId        Int?
  clienteId        Int
  agenteId         Int
  operadoraId      Int?
  idReserva        String?    @db.NVarChar(20)
  etapa            String     @default("LEAD") @db.NVarChar(20)
  status           String     @default("ABERTA") @db.NVarChar(15)
  tipoServico      String     @db.NVarChar(20)
  descricao        String     @db.NVarChar(1000)
  observacoes      String?    @db.NVarChar(1000)
  motivoPerda      String?    @db.NVarChar(500)
  valorEstimado    Decimal    @db.Decimal(10, 2)
  valorComissao    Decimal    @default(0) @db.Decimal(10, 2)
  dataViagemInicio DateTime?
  dataViagemFim    DateTime?
  dataCriacao      DateTime   @default(now())
  proximaAcaoEm    DateTime?
  dataFechamento   DateTime?
  dataPerda        DateTime?

  cliente          Cliente    @relation(fields: [clienteId], references: [id])
  agente           Usuario    @relation(fields: [agenteId], references: [id])
  operadora        Operadora? @relation(fields: [operadoraId], references: [id])
  vendas           Venda[]

  @@map("propostas")
}

model MotivoPerdaProposta {
  id          Int      @id @default(autoincrement())
  empresaId   Int?
  descricao   String   @db.NVarChar(120)
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  @@unique([empresaId, descricao])
  @@map("motivos_perda_proposta")
}

model Venda {
  id                 Int          @id @default(autoincrement())
  empresaId          Int?
  propostaId         Int?
  clienteId          Int
  agenteId           Int
  operadoraId        Int?
  idReserva          String?      @db.NVarChar(20)
  tipoServico        String       @db.NVarChar(20)
  descricao          String       @db.NVarChar(1000)
  observacoes        String?      @db.NVarChar(1000)
  anexoPdfNome       String?      @db.NVarChar(255)
  anexoPdfPath       String?      @db.NVarChar(500)
  valorTotal         Decimal      @db.Decimal(10, 2)
  valorComissao      Decimal      @default(0) @db.Decimal(10, 2)
  status             String       @default("ABERTA") @db.NVarChar(10)
  dataVenda          DateTime     @default(now())
  dataViagemInicio   DateTime?
  dataViagemFim      DateTime?

  proposta           Proposta?    @relation(fields: [propostaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cliente            Cliente      @relation(fields: [clienteId], references: [id])
  agente             Usuario      @relation(fields: [agenteId], references: [id])
  operadora          Operadora?   @relation(fields: [operadoraId], references: [id])
  pagamentos         VendaPagamento[]
  contasReceber      ContaReceber[]
  posVendas          PosVenda[]

  @@map("vendas")
}

model ContaReceber {
  id             Int              @id @default(autoincrement())
  empresaId      Int?
  vendaId        Int
  valor          Decimal          @db.Decimal(10, 2)
  formaPagamento String?          @db.NVarChar(20)
  origem         String           @default("MANUAL") @db.NVarChar(20)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String           @default("PENDENTE") @db.NVarChar(10)

  venda          Venda            @relation(fields: [vendaId], references: [id])

  @@map("contas_receber")
}

model VendaPagamento {
  id             Int       @id @default(autoincrement())
  empresaId      Int?
  vendaId        Int
  formaPagamento String    @db.NVarChar(20)
  valor          Decimal   @db.Decimal(10, 2)
  dataVencimento DateTime?
  dataCriacao    DateTime  @default(now())

  venda          Venda     @relation(fields: [vendaId], references: [id])

  @@map("venda_pagamentos")
}

model ContaPagar {
  id             Int              @id @default(autoincrement())
  empresaId      Int?
  centroCustoId  Int
  descricao      String           @db.NVarChar(500)
  fornecedor     String           @db.NVarChar(150)
  valor          Decimal          @db.Decimal(10, 2)
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String           @default("PENDENTE") @db.NVarChar(10)

  centroCusto    CentroCusto      @relation(fields: [centroCustoId], references: [id])

  @@map("contas_pagar")
}

model CentroCusto {
  id          Int          @id @default(autoincrement())
  empresaId   Int?
  descricao   String       @db.NVarChar(150)
  ativo       Boolean      @default(true)
  dataCriacao DateTime     @default(now())

  contasPagar ContaPagar[]

  @@unique([empresaId, descricao])
  @@map("centros_custo")
}

model PosVenda {
  id          Int          @id @default(autoincrement())
  empresaId   Int?
  vendaId     Int
  tipoAcao    String       @db.NVarChar(20)
  descricao   String       @db.NVarChar(1000)
  dataAcao    DateTime     @default(now())
  responsavel String       @db.NVarChar(150)
  status      String       @default("ABERTO") @db.NVarChar(15)

  venda       Venda        @relation(fields: [vendaId], references: [id])

  @@map("pos_vendas")
}

model ConfiguracaoWhatsApp {
  id               Int     @id @default(autoincrement())
  empresaId        Int?
  mensagemPadrao   String  @db.NVarChar(1000)
  ativo            Boolean @default(true)

  @@map("configuracao_whatsapp")
}

model AuditoriaEvento {
  id          Int      @id @default(autoincrement())
  empresaId   Int?
  entidade    String   @db.NVarChar(80)
  acao        String   @db.NVarChar(60)
  registroId  Int?
  usuarioId   Int?
  usuarioNome String?  @db.NVarChar(150)
  usuarioEmail String? @db.NVarChar(200)
  usuarioPerfil String? @db.NVarChar(20)
  antesJson   String?  @db.NVarChar(4000)
  depoisJson  String?  @db.NVarChar(4000)
  metadadosJson String? @db.NVarChar(4000)
  dataEvento  DateTime @default(now())

  @@index([dataEvento])
  @@index([entidade, dataEvento])
  @@map("auditoria_eventos")
}

model Empresa {
  id             Int      @id @default(autoincrement())
  razaoSocial    String   @db.NVarChar(200)
  nomeFantasia   String?  @db.NVarChar(200)
  cnpj           String?  @db.NVarChar(18)
  subdominio     String?  @unique @db.NVarChar(80)
  email          String?  @db.NVarChar(200)
  telefone       String?  @db.NVarChar(20)
  asaasApiKey    String?  @db.NVarChar(255)
  asaasBaseUrl   String?  @db.NVarChar(255)
  asaasSandbox   Boolean  @default(true)
  ativo          Boolean  @default(true)
  dataCriacao    DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  @@map("empresas")
}

